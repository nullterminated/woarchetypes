WOAutoOpenInBrowser=true

log4j.logger.er.transaction.adaptor.EOAdaptorDebugEnabled=DEBUG
log4j.logger.er.directtoweb.rules.ERD2WTraceRuleFiringEnabled=DEBUG
log4j.logger.com.webobjects.directtoweb.ERD2WUtilities=DEBUG
log4j.logger.er.extensions.ERXAdaptorChannelDelegate.sqlLogging=DEBUG

log4j2.status=debug
loggerPattern=%d{yy-MM-dd HH:mm:ss.SSS} %-5level (%F:%L) - %msg%n